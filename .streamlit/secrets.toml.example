# Template for Streamlit secrets.
#
# LOCAL DEVELOPMENT
#   Copy this file to .streamlit/secrets.toml and paste your real keys.
#   The real file is gitignored.
#
# STREAMLIT CLOUD
#   Don't use this file. Instead, paste these key/value pairs into the
#   "Secrets" panel of your app at share.streamlit.io.

VOYAGE_API_KEY = "pa-your-voyage-key-here"
ANTHROPIC_API_KEY = "sk-ant-your-anthropic-key-here"
