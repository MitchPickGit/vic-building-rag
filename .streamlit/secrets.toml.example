# Template for Streamlit secrets.
#
# LOCAL DEVELOPMENT
#   Copy this file to .streamlit/secrets.toml and paste your real keys.
#   The real file is gitignored.
#
# STREAMLIT CLOUD
#   Don't use this file. Instead, paste these key/value pairs into the
#   "Secrets" panel of your app at share.streamlit.io.

VOYAGE_API_KEY = "pa-your-voyage-key-here"
ANTHROPIC_API_KEY = "sk-ant-your-anthropic-key-here"

# --- Stage 1 hardening ---
# Single shared password the visitor must enter to access the chat UI.
# If unset, the gate is open (useful locally).
APP_PASSWORD = "pick-a-shared-password-for-builder-testing"

# Separate password for the /?admin=1 dashboard (query log, feedback,
# export). Falls back to APP_PASSWORD if not set, so you can leave it
# blank during early prototype testing.
ADMIN_PASSWORD = "pick-a-different-password-for-the-admin-view"
