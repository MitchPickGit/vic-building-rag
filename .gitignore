# Environment
.venv/
.env
__pycache__/
*.pyc

# Source PDFs (large, copyright-sensitive — do not commit)
docs/*.pdf

# Streamlit local secrets (real keys live in Streamlit Cloud's Secrets panel)
.streamlit/secrets.toml

# Briefing zip — not needed in repo
files (1).zip
_zip_extract/

# IDE / OS noise
.DS_Store
.vscode/
.idea/

# Claude Code agent session config (local to each developer's machine)
.claude/

# Test report artefacts — re-generated by run_test_questions.py
test_report*.json
test_report*.md

# Notes
# embeddings.npy and embeddings_cache.jsonl ARE committed so the deployed
# app doesn't need to re-embed on every cold start ($$$ + slow). Generated
# locally by embed_chunks.py.
